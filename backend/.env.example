# Copy this file to .env and adjust the values.
# Every variable is optional in development — sensible defaults apply.

# --- Database ---
# Without a reachable MongoDB the API falls back to an in-memory store
# (works for development, but data resets on every restart).
MONGO_URL=mongodb://localhost:27017
DB_NAME=lush_makeovers

# --- Security (MUST be changed in production) ---
JWT_SECRET=dev-secret-change-me
SEED_ADMIN_EMAIL=admin@lushmakeovers.in
SEED_ADMIN_PASSWORD=Admin@12345

# --- URLs ---
# Comma-separated allowed origins for the browser, e.g. https://lushmakeovers.in
CORS_ORIGINS=*
# Public base URL of the frontend, used to build links inside emails
# (e.g. https://lushmakeovers.in). Defaults to localhost for development.
FRONTEND_URL=http://localhost:3000

# --- Email (Resend) ---
# Get an API key at resend.com. Without one, "forgot password" falls back to
# returning the reset token directly in the API response (dev only).
RESEND_API_KEY=
# Must be on a domain verified in your Resend account. Resend's own test
# domain works out of the box before you verify lushmakeovers.in.
RESEND_FROM_EMAIL=Lush Makeovers <onboarding@resend.dev>

# --- Media storage (Cloudinary) ---
# From cloudinary.com's dashboard. Required — without these, photo uploads
# in the admin Media Library will fail (there is no local-disk fallback,
# since that storage doesn't survive a redeploy on hosts like Render).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional tuning ---
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=30
# CONTENT_DEFAULTS_PATH=../frontend/src/content/defaults.json
